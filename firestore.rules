rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si es el Super Administrador
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == "joseprado049321@gmail.com";
    }

    // Reglas por defecto: el SuperAdmin puede acceder a todo, el resto denegado
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Aislamiento de datos por tienda (Tenant ID)
    match /empresas/{tenantId} {
      // Solo el SuperAdmin, el dueño o los empleados con el mismo tenantId pueden leer/escribir
      allow read, write: if isSuperAdmin() || (request.auth != null && 
        (get(/databases/$(database)/documents/usuarios_acceso/$(request.auth.uid)).data.tenantId == tenantId ||
         get(/databases/$(database)/documents/usuarios_acceso/$(request.auth.uid)).data.rol == 'admin'));

      // Subcolecciones dentro de empresa
      match /{subcollections=**} {
        allow read, write: if isSuperAdmin() || (request.auth != null && 
          (get(/databases/$(database)/documents/usuarios_acceso/$(request.auth.uid)).data.tenantId == tenantId ||
           get(/databases/$(database)/documents/usuarios_acceso/$(request.auth.uid)).data.rol == 'admin'));
      }
    }

    // Acceso a la colección de usuarios
    match /usuarios_acceso/{userId} {
      // Cualquiera autenticado puede leer (para poder listar los usuarios en la interfaz)
      allow read: if request.auth != null;
      // Modificar: SuperAdmin, el mismo usuario, o un 'admin' de una empresa
      allow write: if isSuperAdmin() || (request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/usuarios_acceso/$(request.auth.uid)).data.rol == 'admin'));
    }
  }
}
