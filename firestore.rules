rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Reglas de seguridad estrictas: Requiere autenticación
    match /{document=**} {
      allow read, write: if false;
    }

    // Aislamiento de datos por tienda (Tenant ID)
    match /empresas/{tenantId} {
      // Solo el dueño o los empleados con el mismo tenantId pueden leer/escribir
      allow read, write: if request.auth != null && 
        (get(/databases/$(database)/documents/usuarios_acceso/$(request.auth.uid)).data.tenantId == tenantId ||
         get(/databases/$(database)/documents/usuarios_acceso/$(request.auth.uid)).data.rol == 'admin');

      // Subcolecciones dentro de empresa
      match /{subcollections=**} {
        allow read, write: if request.auth != null && 
          (get(/databases/$(database)/documents/usuarios_acceso/$(request.auth.uid)).data.tenantId == tenantId ||
           get(/databases/$(database)/documents/usuarios_acceso/$(request.auth.uid)).data.rol == 'admin');
      }
    }

    // Acceso a la colección de usuarios
    match /usuarios_acceso/{userId} {
      // Cualquiera autenticado puede leer su propio documento para verificar su rol
      allow read: if request.auth != null;
      // Solo el propio usuario o un admin pueden modificar
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/usuarios_acceso/$(request.auth.uid)).data.rol == 'admin');
    }
  }
}
